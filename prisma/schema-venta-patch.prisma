// Diff exacto para copiar en schema.prisma:

model Venta {
  id             Int      @id @default(autoincrement())
  numero         String   @unique
  fecha          DateTime @default(now())
  clienteNombre  String   @default("Consumidor Final") @map("cliente_nombre")
  clienteNit     String   @default("CF")               @map("cliente_nit")
  clienteCorreo  String?                                @map("cliente_correo")
  subtotal       Float    @default(0)
  descuento      Float    @default(0)
  impuesto       Float    @default(0)
  total          Float    @default(0)
  metodoPago     String   @default("efectivo")          @map("metodo_pago")
  montoRecibido  Float    @default(0)                   @map("monto_recibido")
  cambio         Float    @default(0)
  estado         String   @default("completada")
  notas          String?
  usuarioId      Int?     @map("usuario_id")
  usuarioNombre  String?  @map("usuario_nombre")
  // FEL
  felUuid          String?  @map("fel_uuid")
  felSerie         String?  @map("fel_serie")
  felNumero        Int?     @map("fel_numero")
  felCertificacion String?  @map("fel_certificacion")
  felXml           String?  @map("fel_xml")
  felEstado        String?  @map("fel_estado")

  usuario      Usuario?   @relation(fields: [usuarioId], references: [id])
  items        VentaItem[]
  devoluciones Devolucion[]

  @@map("ventas")
}
